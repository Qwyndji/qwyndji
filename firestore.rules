rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate a generic ID
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate incoming contact message
    function isValidMessage(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.email is string && data.email.size() > 0 && data.email.size() <= 150 && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
          && data.subject is string && data.subject.size() <= 150
          && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
          && data.createdAt == request.time;
    }

    // Messages Collection rules
    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(request.resource.data);
      
      // Allow reading list/documents for displaying in the dynamic inbox/responses demo
      allow read: if true; 
      
      // Allow delete for demo management
      allow delete: if true;
    }
  }
}
